<%= render(Primer::BaseComponent.new(**nav_arguments)) do %>
  <% pages.each do |page| %>
    <% content = capture do %>
      <% if page.key == "page-prev" %>
        <%= render(Primer::Beta::Octicon.new(icon: "chevron-left", "aria-hidden": true)) %>
      <% end %>

      <%= page.content %>

      <% if page.key == "page-next" %>
        <%= render(Primer::Beta::Octicon.new(icon: "chevron-right", "aria-hidden": true)) %>
      <% end %>
    <% end %>

    <% if page.props[:href].present? %>
      <%= link_to page.props[:href], page.props.except(:href) do %>
        <%= content %>
      <% end %>
    <% else %>
      <%= content_tag(:span, content, **page.props) %>
    <% end %>
  <% end %>
<% end %>
